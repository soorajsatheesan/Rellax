# Copy to .env.local and fill in values. Never commit secrets.

# Convex (from `npx convex dev` or dashboard)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
# Optional: Convex HTTP actions / site URL (not read by current Next.js code)
NEXT_PUBLIC_CONVEX_SITE_URL=

# WorkOS AuthKit
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Job description AI (role requirements) — uses xAI Grok API
XAI_API_KEY=
XAI_JD_ANALYSIS_MODEL=grok-4.20-0309-reasoning

# Employee learning generation
OPENAI_API_KEY=
OPENAI_LEARNING_MODEL=gpt-4.1-mini

# Google Cloud Text-to-Speech — service account auth (pick ONE option below)
# Option A: inline JSON — matches the key name from your .env.local (recommended)
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","token_uri":"https://oauth2.googleapis.com/token"}'
# Option B: path to the downloaded service-account JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Voice settings
GOOGLE_TTS_VOICE=en-US-Neural2-J
GOOGLE_TTS_LANGUAGE=en-US
GOOGLE_TTS_SPEAKING_RATE=0.95
# Available Neural2 voices: en-US-Neural2-A (female), en-US-Neural2-D (male), en-US-Neural2-J (male, warm), en-US-Neural2-F (female, warm)
